	(text "\n24V from the printer is passed through resistor divider \nR4:R5 to give ~7.67V to the inverting input of  \ncomparator A in the LM393 dual comparator chip"
		(exclude_from_sim no)
		(at 205.232 67.31 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "032e95b1-8753-4b21-8678-6737937eb178")
	)
	(text "24V voltage comparator stage"
		(exclude_from_sim no)
		(at 203.454 63.246 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "0a8f6899-bd68-46b1-8799-fa734d86ca01")
	)
	(text "Hotend temperature monitor stage"
		(exclude_from_sim no)
		(at 204.216 117.602 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "38b4efe3-6864-4883-9ba8-2b7082c6c7cf")
	)
	(text "iys not possible to use a single thermistor fofr both the 3d printer and the back up\nsupply board. unless theres a well thought of 3.3v line \nsolution is to use a seperate tmtperatur emonitroing circuit with an independent themistor\n"
		(exclude_from_sim no)
		(at 71.12 64.008 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "43affeed-924f-4e60-b80d-ef39841a0ed5")
	)
	(text "add reverse protection \non the power input side, \nas well ass the battery side\n"
		(exclude_from_sim no)
		(at 29.972 21.59 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
				(color 194 0 0 1)
			)
		)
		(uuid "5bb2a217-a33c-4951-8b91-66b269a2f955")
	)
	(text "3pin battery terminal\n"
		(exclude_from_sim no)
		(at 174.498 46.736 90)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "78578d7d-1610-4ad3-8fb2-d885dcecd6ad")
	)
	(text "Battery Charger stage\noutput range [3.2:4.2V]"
		(exclude_from_sim no)
		(at 137.16 16.002 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "79d3d69f-365c-4f58-a638-37970aeef039")
	)
	(text "in the absence \nof 24V,comparator\noutput pulls \nthe gate of \nQ1 to ground \nturnig the\nfan on!"
		(exclude_from_sim no)
		(at 242.824 80.772 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7acd22a7-9850-4243-a099-e286ab265536")
	)
	(text "100k NTc thermistor \nfrom 3d printer \nboard\ninternally pulled up to \n3.3v, and appropriate\nvoltage divider already\nimplemented"
		(exclude_from_sim no)
		(at 120.65 143.002 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7f7e083d-7784-42b7-8bbb-a730a7d744a9")
	)
	(text "12V boost stage"
		(exclude_from_sim no)
		(at 208.534 14.986 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "8b0d8e96-8971-4a95-b5b7-6322e5e5eb67")
	)
	(text "resistor network R8:R7 \ncan be replaced with\npotentiometer RV1 to \nset the threshold voltage\ncorresponding to the \ndesired temperature to\nturn the fan on [>50C]\nmust be something below\n3.3 logic voltage"
		(exclude_from_sim no)
		(at 220.98 151.638 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8d09210a-1632-4c42-83c5-5bdbbe5ab873")
	)
	(text "12V_Boosted is\npassed through \ndivider R3:R2 \ngiving ~6V to\nnon_inverting\ninput of\ncomparator A\n\n\n"
		(exclude_from_sim no)
		(at 242.824 38.862 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "b24dc54e-e9b2-4094-a663-cc1a391dba34")
	)
	(text "24V step down buck converter stage5V output to \nbattery charger"
		(exclude_from_sim no)
		(at 58.42 15.748 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "b2f79913-fd59-479e-adf2-26463eba1ba8")
	)
	(text "mosfet Q2 is\ndriven by output\nof divider R4:R5\nto ground the motor\ncontacts when 24V is\navailable, retaining\nnormal control of the \nhotend by the 3Dprinter\ncontrol board\n"
		(exclude_from_sim no)
